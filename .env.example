# ============================================
# AssetFlow — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================

# ---- Database ----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=assetflow_dev
DATABASE_USER=assetflow
DATABASE_PASSWORD=assetflow_dev
DATABASE_URL=postgresql://assetflow:assetflow_dev@localhost:5432/assetflow_dev

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-to-a-256-bit-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-256-bit-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ---- Object Storage (S3-compatible) ----
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=assetflow-uploads
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

# ---- Email / SMTP ----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
SMTP_FROM=noreply@assetflow.local

# ---- Rate Limiting ----
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
RATE_LIMIT_FORGOT_PASSWORD=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MINUTES=60
RATE_LIMIT_GENERAL=100
RATE_LIMIT_GENERAL_WINDOW_MINUTES=1

# ---- Scheduled Jobs (cron expressions) ----
CRON_OVERDUE_CHECK=*/15 * * * *
CRON_BOOKING_TRANSITION=*/5 * * * *
CRON_BOOKING_REMINDER=*/5 * * * *
BOOKING_REMINDER_LOOKAHEAD_MINUTES=30

# ---- Redis (for rate limiting / caching) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- App ----
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
